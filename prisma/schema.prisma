generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  role            String   @default("USER") // ADMIN | USER
  passwordHash    String?
  age             Int      @default(25)
  weightKg        Float    @default(75)
  heightCm        Float    @default(175)
  photoUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workoutPlans    WorkoutPlan[]
  workoutSessions WorkoutSession[]
  progressPhotos  ProgressPhoto[]
  mealPlans       MealPlan[]
  dailyMealLogs   DailyMealLog[]
  sentMessages       Message[] @relation("SentMessages")
  receivedMessages   Message[] @relation("ReceivedMessages")
  scheduledWorkouts  ScheduledWorkout[]
  pushSubscriptions  PushSubscription[]
  notifications      Notification[]
}

model Exercise {
  id          String  @id @default(cuid())
  name        String  @unique
  nameHe      String
  muscleGroup String  // CHEST | BACK | LEGS | SHOULDERS | BICEPS | TRICEPS | ABS | CARDIO | FUNCTIONAL | GLUTES | CALVES | OTHER
  lottieFile  String
  description String?

  planExercises    WorkoutPlanExercise[]
  sessionExercises SessionExercise[]
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  workoutType String   // PUSH | PULL | LEGS | CHEST_BACK | SHOULDERS_ARMS
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]
  sessions  WorkoutSession[]

  @@unique([userId, workoutType])
}

model WorkoutPlanExercise {
  id             String @id @default(cuid())
  planId         String
  exerciseId     String
  orderIndex     Int
  sets           Int    @default(3)
  reps           Int    @default(10)
  targetWeightKg Float  @default(0)

  plan     WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([planId, exerciseId])
  @@unique([planId, orderIndex])
}

model WorkoutSession {
  id               String    @id @default(cuid())
  userId           String
  planId           String
  workoutType      String    // PUSH | PULL | LEGS | CHEST_BACK | SHOULDERS_ARMS
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  difficultyRating Int?

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      WorkoutPlan       @relation(fields: [planId], references: [id])
  exercises SessionExercise[]
}

model SessionExercise {
  id             String  @id @default(cuid())
  sessionId      String
  exerciseId     String
  orderIndex     Int
  sets           Int
  reps           Int
  weightUsedKg   Float
  weightsPerSet  String? // JSON array e.g. "[20,22.5,25,25]"
  status         String  @default("PENDING") // PENDING | SUCCESS | PARTIAL | FAIL

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@unique([sessionId, orderIndex])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  photoUrl  String
  takenAt   DateTime @default(now())
  monthYear String   // "2026-03"
  weightKg  Float?
  notes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthYear])
}

model Food {
  id          String @id @default(cuid())
  name        String @unique
  nameHe      String
  caloriesPer100g Float
  proteinPer100g  Float @default(0)
  carbsPer100g    Float @default(0)
  fatPer100g      Float @default(0)
  category    String // PROTEIN | CARB | FAT | VEGETABLE | FRUIT | DAIRY | SNACK | DRINK | OTHER

  mealFoods   MealPlanMealFood[]
}

model MealPlan {
  id             String   @id @default(cuid())
  userId         String
  goal           String   // BULK | CUT
  targetCalories Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals MealPlanMeal[]
}

model MealPlanMeal {
  id         String @id @default(cuid())
  planId     String
  name       String // e.g. "ארוחת בוקר", "ארוחת צהריים"
  orderIndex Int

  plan  MealPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  foods MealPlanMealFood[]

  @@unique([planId, orderIndex])
}

model MealPlanMealFood {
  id       String @id @default(cuid())
  mealId   String
  foodId   String
  amountGrams Float

  meal MealPlanMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food         @relation(fields: [foodId], references: [id])

  @@unique([mealId, foodId])
}

model DailyMealLog {
  id     String   @id @default(cuid())
  userId String
  mealId String
  date   DateTime @db.Date
  eaten  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId, date])
}

model ScheduledWorkout {
  id          String   @id @default(cuid())
  userId      String
  workoutType String   // PUSH | PULL | LEGS | CHEST_BACK | SHOULDERS_ARMS | FULL_BODY
  date        DateTime? @db.Date   // specific date (null if recurring)
  dayOfWeek   Int?                  // 0=Sun..6=Sat (null if specific date)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, dayOfWeek])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, read])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CHAT_MESSAGE | WORKOUT_REMINDER
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
